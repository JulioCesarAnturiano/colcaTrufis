<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows cleartext HTTP traffic for the local development/staging backend.
  Production builds should use HTTPS and a stricter config or remove this file.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
