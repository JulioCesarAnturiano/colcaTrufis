<h2>3.4. Modelos y Relaciones</h2>

<h3>3.4.1. Modelo Sindicato</h3>
<pre>
class Sindicato extends Model
{
    protected $fillable = ['nombre', 'sigla', 'representante_legal',
                          'telefono', 'direccion', 'estado'];

    public function rutas()
    {
        return $this->hasMany(Ruta::class);
    }

    public function trufis()
    {
        return $this->hasManyThrough(Trufi::class, Ruta::class);
    }
}
</pre>

<h3>3.4.2. Modelo Ruta</h3>
<pre>
class Ruta extends Model
{
    protected $fillable = ['numero', 'nombre', 'origen', 'destino',
                          'distancia_km', 'tarifa', 'horario_inicio',
                          'horario_fin', 'sindicato_id', 'estado'];

    public function sindicato()
    {
        return $this->belongsTo(Sindicato::class);
    }

    public function paradas()
    {
        return $this->hasMany(Parada::class);
    }

    public function trufis()
    {
        return $this->hasMany(Trufi::class);
    }
}
</pre>

<h3>3.4.3. Modelo Trufi</h3>
<pre>
class Trufi extends Model
{
    protected $fillable = ['placa', 'propietario', 'conductor',
                          'telefono_conductor', 'ruta_id', 'estado'];

    public function ruta()
    {
        return $this->belongsTo(Ruta::class);
    }
}
</pre>

<h2>3.5. Controladores</h2>

<h3>3.5.1. API Controllers (app/Http/Controllers/Api/)</h3>

<h4>RutaController.php</h4>
<pre>
class RutaController extends Controller
{
    public function index()
    {
        $rutas = Ruta::with(['sindicato', 'paradas'])
                     ->where('estado', 'activo')
                     ->get();

        return response()->json([
            'success' => true,
            'data' => $rutas
        ]);
    }

    public function show($id)
    {
        $ruta = Ruta::with(['sindicato', 'paradas', 'trufis'])
                    ->findOrFail($id);

        return response()->json([
            'success' => true,
            'data' => $ruta
        ]);
    }
}
</pre>

<h3>3.5.2. Web Controllers (app/Http/Controllers/Web/)</h3>

<h4>DashboardController.php</h4>
<pre>
class DashboardController extends Controller
{
    public function index()
    {
        $stats = [
            'total_rutas' => Ruta::count(),
            'total_trufis' => Trufi::count(),
            'total_sindicatos' => Sindicato::count(),
            'reclamos_pendientes' => Reclamo::where('estado', 'pendiente')->count()
        ];

        return view('dashboard', compact('stats'));
    }
}
</pre>

<h2>3.6. Rutas Web y API</h2>

<h3>routes/web.php</h3>
<pre>
Route::middleware(['auth'])->group(function () {
    Route::get('/dashboard', [DashboardController::class, 'index']);
    Route::resource('sindicatos', SindicatoController::class);
    Route::resource('rutas', RutaController::class);
    Route::resource('trufis', TrufiController::class);
    Route::resource('radiotaxis', RadiotaxiController::class);
    Route::resource('referencias', ReferenciaController::class);
    Route::resource('normativas', NormativaController::class);
    Route::resource('reclamos', ReclamoController::class);
    Route::get('/reportes', [ReporteController::class, 'index']);
    Route::get('/reportes/exportar', [ReporteController::class, 'exportar']);
});
</pre>

<h3>routes/api.php</h3>
<pre>
Route::prefix('v1')->group(function () {
    Route::get('rutas', [Api\RutaController::class, 'index']);
    Route::get('rutas/{id}', [Api\RutaController::class, 'show']);
    Route::get('radiotaxis', [Api\RadiotaxiController::class, 'index']);
    Route::get('referencias', [Api\ReferenciaController::class, 'index']);
    Route::get('normativas', [Api\NormativaController::class, 'index']);
    Route::post('reclamos', [Api\ReclamoController::class, 'store']);
    Route::get('reclamos/{codigo}', [Api\ReclamoController::class, 'show']);
});
</pre>

<h2>3.7. Servicios y Autenticación</h2>
<p>El sistema utiliza el sistema de autenticación integrado de Laravel con middleware <code>auth</code> para proteger rutas del panel administrativo. Los servicios encapsulan la lógica de negocio para operaciones complejas como generación de reportes y procesamiento de reclamos.</p>

